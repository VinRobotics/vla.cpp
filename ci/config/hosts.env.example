#
# TEMPLATE - copy to ci/config/hosts.env and fill in your own values:
#   cp ci/config/hosts.env.example ci/config/hosts.env
# hosts.env is gitignored: it is the ONLY place real hostnames / IPs / paths
# live, so none of that lands in the repo. Keep this template placeholder-only.
# Bash-sourceable; every value can also be overridden from the environment
# (e.g. injected by the CI runner from GitHub Actions secrets).
#
# Topology (decoupled): one ORCHESTRATOR host runs the GitHub Actions self-hosted
# runner and the LIBERO client for ALL platforms. Every platform is a REMOTE
# SERVER - only vla-server + GGUF weights live on the target; the orchestrator
# connects out to it over the LAN. Platforms (stable keys; not host names):
#   rtx3060 -> an RTX 3060 server     (CUDA, sm_86)
#   orin    -> a Jetson Orin Nano     (CUDA/Tegra, sm_87)
#   m4      -> an Apple M4 server      (Metal)
#
# NETWORKING - everything is on the LAN now (no SSH). Two planes per server, both
# dialled at the server's LAN IP (*_SERVER_HOST), on different ports:
#   *_CTRL_PORT   = CONTROL plane: vla-ci-ctl <-> vla-ci-agent (push code, build,
#                   spawn/stop the server, fetch logs). Replaces SSH.
#   *_SERVER_PORT = DATA plane: the LIBERO client <-> vla-server ZMQ calls.
# *_SERVER_HOST MUST be a LOCAL-SUBNET IP (e.g. 192.168.1.*). Do NOT use a
# Tailscale hostname or 100.x IP - that routes over the WireGuard tunnel and
# inflates the latency these benchmarks measure. (vla-server binds tcp://*:PORT
# and vla-ci-agent binds tcp://*:CTRL_PORT, so both already listen on the LAN IP;
# you only have to point the orchestrator at the right one.)

# Optional shared secret for the control plane. If set, start each vla-ci-agent
# with the SAME token (--token / VLA_CI_TOKEN) or it will reject requests.
VLA_CI_TOKEN="${VLA_CI_TOKEN:-}"

# ── orchestrator (THIS machine during CI - runner + all clients) ────────────
ORCH_REPO_ROOT="${ORCH_REPO_ROOT:-/path/to/vla.cpp}"           # repo checkout on the orchestrator
ORCH_MODELS_ROOT="${ORCH_MODELS_ROOT:-/path/to/models}"        # GR00T dataset_statistics.json (client-side un-norm); tiny, copy from any server
LIBERO_VENV_PY="${LIBERO_VENV_PY:-${ORCH_REPO_ROOT}/eval/sim/libero/libero_uv/.venv/bin/python}"
CI_OUTPUT_ROOT="${CI_OUTPUT_ROOT:-${ORCH_REPO_ROOT}/outputs/ci}"

# ── rtx3060 platform → RTX 3060 server ──────────────────────────────────────
RTX_REPO_ROOT="${RTX_REPO_ROOT:-/path/to/vla.cpp}" # repo path on the server
RTX_MODELS_ROOT="${RTX_MODELS_ROOT:-/path/to/models}"
RTX_SERVER_HOST="${RTX_SERVER_HOST:-192.168.1.10}" # LAN IP only (192.168.1.*); NOT a Tailscale name/IP
RTX_SERVER_PORT="${RTX_SERVER_PORT:-5555}"         # data plane (vla-server)
RTX_CTRL_PORT="${RTX_CTRL_PORT:-5600}"             # control plane (vla-ci-agent)
RTX_CMAKE_FLAGS="${RTX_CMAKE_FLAGS:--DGGML_CUDA=ON -DGGML_CUDA_GRAPHS=ON -DCMAKE_CUDA_ARCHITECTURES=86}"

# ── orin platform → Jetson Orin Nano server ─────────────────────────────────
ORIN_REPO_ROOT="${ORIN_REPO_ROOT:-/path/to/vla.cpp}"
ORIN_MODELS_ROOT="${ORIN_MODELS_ROOT:-/path/to/models}"
ORIN_SERVER_HOST="${ORIN_SERVER_HOST:-192.168.1.11}" # LAN IP only (192.168.1.*); NOT a Tailscale name/IP
ORIN_SERVER_PORT="${ORIN_SERVER_PORT:-5555}"
ORIN_CTRL_PORT="${ORIN_CTRL_PORT:-5600}"
ORIN_CMAKE_FLAGS="${ORIN_CMAKE_FLAGS:--DGGML_CUDA=ON -DGGML_CUDA_GRAPHS=ON -DCMAKE_CUDA_ARCHITECTURES=87}"

# ── m4 platform → Apple M4 server (Metal auto-detected) ─────────────────────
M4_REPO_ROOT="${M4_REPO_ROOT:-/path/to/vla.cpp}"
M4_MODELS_ROOT="${M4_MODELS_ROOT:-/path/to/models}"
M4_SERVER_HOST="${M4_SERVER_HOST:-192.168.1.12}"   # LAN IP only (192.168.1.*); NOT a Tailscale name/IP
M4_SERVER_PORT="${M4_SERVER_PORT:-5555}"
M4_CTRL_PORT="${M4_CTRL_PORT:-5600}"
M4_CMAKE_FLAGS="${M4_CMAKE_FLAGS:-}"               # Metal is on by default on macOS; no CUDA flags
