# Copyright 2026 VinRobotics - Apache-2.0
#
# CI test matrix: which models / suites run on each platform, and the per-arch
# action-chunk replay. Single source of truth; sourced by the runners and passed
# to check_thresholds.py. Bash-sourceable (no spaces around '=').

# Per-arch n_action_steps (chunk replay) - matches eval/run_libero.sh closeouts.
NACT_smolvla=1
NACT_pi0=50
NACT_evo1=8
NACT_bitvla=8
NACT_gr00t_n1_5=16
NACT_gr00t_n1_6=16
NACT_gr00t_n1_7=16

nact_for() { local v="NACT_$1"; echo "${!v:-1}"; }

# Default suite every (platform, model) runs: 10 tasks × 1 episode.
DEFAULT_SUITE="libero_object"
N_EPISODES=1

# Per-platform model sets (all run with the client on the orchestrator and the
# server on the platform's target host - see ci/config/hosts.env).
#   rtx3060 : all 7
#   orin    : all except gr00t_n1_6/_7
#   m4      : smolvla, pi0, gr00t_n1_7
MODELS_rtx3060="smolvla pi0 bitvla evo1 gr00t_n1_5 gr00t_n1_6 gr00t_n1_7"
MODELS_orin="smolvla pi0 bitvla evo1 gr00t_n1_5"
MODELS_m4="smolvla pi0 gr00t_n1_7"

models_for() { local v="MODELS_$1"; echo "${!v}"; }

# Extra multi-suite coverage on RTX 3060 only: these models also run the full
# 4-suite set (10×1 each). "long" == libero_10 in this repo.
MULTISUITE_MODELS_rtx3060="bitvla gr00t_n1_7"
MULTISUITE_SUITES="libero_spatial libero_object libero_goal libero_10"

multisuite_models_for() { local v="MULTISUITE_MODELS_$1"; echo "${!v:-}"; }

# Suites a given (platform, model) should run = DEFAULT_SUITE, plus the
# multisuite set if the model is listed for that platform.
suites_for() {
    local platform="$1" model="$2"
    local extra; extra="$(multisuite_models_for "$platform")"
    for m in $extra; do
        if [[ "$m" == "$model" ]]; then echo "$MULTISUITE_SUITES"; return; fi
    done
    echo "$DEFAULT_SUITE"
}
